# Base URL of the Astro Exchange bot's Express API (no trailing slash).
# Example: https://astro-exchange-bot.up.railway.app
NEXT_PUBLIC_ASTRO_API_URL=

# Discord invite link, used for "Join Discord" CTAs across the site.
NEXT_PUBLIC_DISCORD_INVITE=https://discord.gg/your-invite

# Link to the Discord-based digital shop, used for "Visit Shop" CTAs.
NEXT_PUBLIC_SHOP_URL=https://discord.gg/your-invite
